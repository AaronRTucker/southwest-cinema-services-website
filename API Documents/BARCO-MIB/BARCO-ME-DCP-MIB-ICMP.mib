		-- 1.3.6.1.4.1.12612.220.12.4
        barcoMediaServerCompl MODULE-COMPLIANCE
            STATUS  current
            DESCRIPTION
                "The compliance statement for Barco Media Servers."
            MODULE  -- this module
            MANDATORY-GROUPS
                {
		        icmpInfoGroup,
				icmpSensorsGroup,
				icmpStorageGroup,
				icmpRaidGroup,
				icmpIngestGroup,
				icmpPlayerGroup,
				icmpSchedulerGroup,
				icmpNotificationGroup,
				icmpTrapGroup
                }
                
            ::= { barcoDcpConfsCompliance 4 }

