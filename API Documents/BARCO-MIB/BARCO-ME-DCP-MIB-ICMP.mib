-- Group definitions

		-- 1.3.6.1.4.1.12612.220.11.5.6
		icmpGroups	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION 
				"This is the general oid for the groups."
			::= { rootBmeDcMediaServerMonMIB 6 }

		-- 1.3.6.1.4.1.12612.220.11.5.6.1
		icmpInfoGroup	OBJECT-GROUP
			OBJECTS	{ icmpSerialNumber, icmpHostName, icmpState, icmpSoftwareVersion, icmpMediaBlockCertifID,
			          icmpLicenseName, icmpLicenseNotValidBefore, icmpLicenseNotValidAfter, icmpMode2D3D, icmpBackplaneTest }
			STATUS	current
			DESCRIPTION 
				"A collection of all server general information."
			::= { icmpGroups 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.6.2
		icmpSensorsGroup	OBJECT-GROUP
			OBJECTS	{ icmpTemperatureName, icmpTemperature, icmpTemperatureDiagnosis, 
			          icmpVoltageName,     icmpVoltage,     icmpVoltageDiagnosis, 
			          icmpFanSpeedName,    icmpFanSpeed,    icmpFanSpeedDiagnosis  }
			STATUS	current
			DESCRIPTION
				"A collection of all ICMP diagnosis properties"
			::= { icmpGroups 2 }

   		-- 1.3.6.1.4.1.12612.220.11.5.6.3
		icmpRaidGroup	OBJECT-GROUP
			OBJECTS	{ icmpInternalRaidModel, icmpInternalRaidSerialNumber, icmpInternalRaidStatus, 
			          icmpInternalRaidRebuildPercentage, raidDiskSerialNumber, raidDiskSize, raidDiskStatus,
                      icmpInternalRaidTotalSize }
			STATUS	current
			DESCRIPTION 
				"A collection of all server raid array information."
			::= { icmpGroups 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.6.4
		icmpStorageGroup	OBJECT-GROUP
			OBJECTS	{ storageName, storageType, storageTotalSize, storageFreeSize }
			STATUS	current
			DESCRIPTION 
				"A collection of all server storage information."
			::= { icmpGroups 4 }     

		-- 1.3.6.1.4.1.12612.220.11.5.6.5
		icmpIngestGroup	OBJECT-GROUP
			OBJECTS	{ icmpIngestCurrentJobStatus, icmpIngestJobsPending, icmpIngestSourceType,
			          icmpIngestSourceName, icmpIngestSourceConnectionStatus, icmpIngestStartTime,
			          icmpIngestPercentageCompleted, icmpIngestElapsedTime }
			STATUS	current
			DESCRIPTION 
				"A collection of all Media Server ingest information."
			::= { icmpGroups 5 }

		-- 1.3.6.1.4.1.12612.220.11.5.6.6
		icmpPlayerGroup	OBJECT-GROUP
			OBJECTS	{ icmpPlayMode, icmpPlayState, icmpPlaySelectContentTitle,
			          icmpPlaySelectContentDuration, icmpPlaySelectStartTime, icmpPlayCurrentContentTitle,
			          icmpPlayStartTime, icmpPlayPosition, icmpPlayFromAlternativeSource, icmpPlayNextScheduledContentTitle,
			          icmpPlayNextScheduledContentDuration, icmpPlayNextScheduledStartTime, icmpPlayNextScheduledValidity }
			STATUS	current
			DESCRIPTION 
				"A collection of all Media Server player information."
			::= { icmpGroups 6 }

		-- 1.3.6.1.4.1.12612.220.11.5.6.7
		icmpSchedulerGroup	OBJECT-GROUP
			OBJECTS	{ unplayableContentShowTitle, unplayableContentTime, unplayableContentReason }
			STATUS	current
			DESCRIPTION 
				"A collection of all Media Server scheduler information."
			::= { icmpGroups 7 }

		-- 1.3.6.1.4.1.12612.220.11.5.6.8
		icmpNotificationGroup	NOTIFICATION-GROUP
			NOTIFICATIONS	{ icmpTemperatureFail, icmpVoltageFail, icmpFanSpeedFail,
			                  icmpTemperatureWarning, icmpVoltageWarning, icmpFanSpeedWarning,
			                  icmpRaidError, icmpRaidWarning, icmpRaidDiskError, icmpRaidDiskWarning,
			                  icmpStorageError, icmpStorageWarning, icmpIngestError, icmpIngestWarning,
			                  icmpContentDatabaseError, icmpContentDatabaseWarning, icmpPlayerError, 
			                  icmpPlayerWarning, icmpSchedulerError, icmpSchedulerWarning }
			STATUS	current
			DESCRIPTION
				"The collection of all Media Server notifications."
			::= { icmpGroups 8 }

		-- 1.3.6.1.4.1.12612.220.11.5.6.9
		icmpTrapGroup	NOTIFICATION-GROUP
			NOTIFICATIONS	{ trapIcmpTemperatureFail, trapIcmpVoltageFail, trapIcmpFanSpeedFail,
			                  trapIcmpTemperatureWarning, trapIcmpVoltageWarning, trapIcmpFanSpeedWarning,
			                  trapIcmpRaidError, trapIcmpRaidWarning, trapIcmpRaidDiskError, trapIcmpRaidDiskWarning,
			                  trapIcmpStorageError, trapIcmpStorageWarning, trapIcmpIngestError, trapIcmpIngestWarning,
			                  trapIcmpContentDatabaseError, trapIcmpContentDatabaseWarning, trapIcmpPlayerError, 
			                  trapIcmpPlayerWarning, trapIcmpSchedulerError, trapIcmpSchedulerWarning }

			STATUS	current
			DESCRIPTION
				"The collection of all Media Server traps."
			::= { icmpGroups 9 }

-- END OF BARCO-ME-DC-MEDIASERVER-MON-MIB mib


-- Conformance information

		-- 1.3.6.1.4.1.12612.220.12.1
        barcoDp100Compl MODULE-COMPLIANCE
            STATUS  current
            DESCRIPTION
                "The compliance statement for DP90/DP100/DP300 projectors."
            MODULE  -- this module
            MANDATORY-GROUPS
                {
                comCommonGroup,
                tiDp100SpecificGroup,
                tiS1CommonGroup,
                tiDmdNativeSizeGroup,
                tiS1ConfigGroup,
                projDp100SpecificGroup,
                projCommonGroup,
                projCommonLampGroup,
                dp100CommonGroup,
                dp100DiagnosisGroup
                }
                
			GROUP	tiNotificationGroup
			DESCRIPTION	"Notifications only available is snmp v2 is selected."
			GROUP	projNotificationGroup
			DESCRIPTION	"Notifications only available is snmp v2 is selected.
            Notifications: lampOffByProjector, lampNoStrike, dowserNotOpen, globalFailure,
            globalError, globalWarning, globalNotif, communicationWarning are not supported."
			GROUP	dp100NotificationGroup
			DESCRIPTION	"Notifications only available is snmp v2 is selected."
            
			GROUP	tiTrapGroup
			DESCRIPTION	"Traps only available is snmp v1 is selected."
			GROUP	projTrapGroup
			DESCRIPTION	"Traps only available is snmp v1 is selected.
            Traps: trapLampOffByProjector, trapLampNoStrike, trapDowserNotOpen, trapGlobalFailure,
            trapGlobalError, trapGlobalWarning, trapGlobalNotif, trapCommunicationWarning are not supported."
			GROUP	dp100TrapGroup
			DESCRIPTION	"Traps only available is snmp v1 is selected."
            
            ::= { barcoDcpConfsCompliance 1 }

		-- 1.3.6.1.4.1.12612.220.12.2
