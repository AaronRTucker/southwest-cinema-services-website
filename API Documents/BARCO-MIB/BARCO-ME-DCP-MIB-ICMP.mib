		-- 1.3.6.1.4.1.12612.220.11.4.2.3
		presetActive	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"The name of the active preset."
			::= { dpProp2Monitor 3 }

		-- 1.3.6.1.4.1.12612.220.11.4.2.5
		s2Inputs	OBJECT-IDENTITY
			STATUS 	current
			DESCRIPTION
				"This is the general oid for the inputs properties (Series2 only)."
			::= { dpProp2Monitor 5 }
             
		-- 1.3.6.1.4.1.12612.220.11.4.2.5.1
		s2InputSelected	OBJECT-TYPE
			SYNTAX INTEGER
				{
				undetermined(0),
				sMPTE292A(1),
				sMPTE292B(2),
				sMPTE292Dual(3),
				dVIA(4),
				dVIB(5),
				dVIDualTwin(6),
				sMPTE2923D(7),
				dVI3D(8),
				internalMediaBlock(9),
				dVI4K(10),
				sMPTE424A(11),
				sMPTE424B(12),
				sMPTE4243D(13)
				}
			UNITS	"enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"The status of the input selection.
				sMPTE292A:      SMPTE 292-A
				sMPTE292B:      SMPTE 292-B
				sMPTE292Dual:   SMPTE 292-Dual
				dVIA:           DVI-A
				dVIB:           DVI-B
				dVIDualTwin:    DVI-Dual/Twin
				sMPTE2923D:     SMPTE 292 3D
				dVI3D:          DVI 3D
				internalMediaBlock :  Internal Media Block (IMB)
				dVI4K:          DVI 4K (using horizontal spanning)      
				sMPTE424A:      SMPTE 424-A  (3G)
				sMPTE424B:      SMPTE 424-B  (3G)
				sMPTE4243D:     SMPTE 424-3D (3G)
				"
			::= { s2Inputs 1 }
			
		-- 1.3.6.1.4.1.12612.220.11.4.2.5.2
		s2InputFileSelected	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the name of the input file selected (Series2 only)."
			::= { s2Inputs 2 }

-- Notifications

		-- 1.3.6.1.4.1.12612.220.11.4.3
		barcoMeDcDPS1S2Notifications	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the general oid for Barco DP2000 notifications (Series2 only)."
			::= { rootBmeDcDPS1S2MonMIB 3 }


		-- 1.3.6.1.4.1.12612.220.11.4.3.0
		dpNotificationPrefix	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the prefix used to have easy event mapping
				between notification oid values (SNMPv2 and SNMPv3) and
				specific trap numbers (SNMPv1)."
			::= { barcoMeDcDPS1S2Notifications 0 }


		-- 1.3.6.1.4.1.12612.220.11.4.3.0.6
		temperatureFail	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a critical severity and is sent the moment of
				exceeding one of the temperature boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { dpNotificationPrefix 6 }


		-- 1.3.6.1.4.1.12612.220.11.4.3.0.7
		voltageFail	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This has a critical severity and is sent the moment of
				exceeding one of the voltage boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { dpNotificationPrefix 7 }


		-- 1.3.6.1.4.1.12612.220.11.4.3.0.8
		fanSpeedFail	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a major severity and is sent the moment of
				exceeding one of the fan speed boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { dpNotificationPrefix 8 }


		-- 1.3.6.1.4.1.12612.220.11.4.3.0.10
		temperatureWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the temperature boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { dpNotificationPrefix 10 }


		-- 1.3.6.1.4.1.12612.220.11.4.3.0.11
		voltageWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the voltage boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { dpNotificationPrefix 11 }


		-- 1.3.6.1.4.1.12612.220.11.4.3.0.12
		fanSpeedWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the fanspeed boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { dpNotificationPrefix 12 }


-- Trap defines
-- In order to be backwards compatible, also SNMPv1 traps are foreseen.

		trapTemperatureFail	TRAP-TYPE
			ENTERPRISE	temperatureFail
			VARIABLES	{ eventSeverity, eventDescription, eventDetail }
			DESCRIPTION
				"This trap has a critical severity and is sent the moment of
				exceeding one of the temperature boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
	        REFERENCE	"[specific-trap]"
			::= 6


		trapVoltageFail	TRAP-TYPE
			ENTERPRISE	voltageFail
			VARIABLES	{ eventSeverity, eventDescription, eventDetail }
			DESCRIPTION
				"This has a critical severity and is sent the moment of
				exceeding one of the voltage boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			REFERENCE	"[specific-trap]"
			::= 7


		trapFanSpeedFail	TRAP-TYPE
			ENTERPRISE	fanSpeedFail
			VARIABLES	{ eventSeverity, eventDescription, eventDetail }
			DESCRIPTION
				"This has a major severity and is sent the moment of
				exceeding one of the fan speed boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			REFERENCE	"[specific-trap]"
			::= 8


		trapTemperatureWarning	TRAP-TYPE
			ENTERPRISE	temperatureWarning
			VARIABLES	{ eventSeverity, eventDescription, eventDetail }
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the temperature warning boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
	        REFERENCE	"[specific-trap]"
			::= 10


		trapVoltageWarning	TRAP-TYPE
			ENTERPRISE	voltageWarning
			VARIABLES	{ eventSeverity, eventDescription, eventDetail }
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the voltage warning boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
	        REFERENCE	"[specific-trap]"
			::= 11


		trapFanSpeedWarning	TRAP-TYPE
			ENTERPRISE	fanSpeedWarning
			VARIABLES	{ eventSeverity, eventDescription, eventDetail }
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the fanspeed warning boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
	        REFERENCE	"[specific-trap]"
			::= 12


-- Group definitions

		-- 1.3.6.1.4.1.12612.220.11.4.4
		dpGroups	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION 
				"This is the general oid for the groups."
			::= { rootBmeDcDPS1S2MonMIB 4 }

		-- 1.3.6.1.4.1.12612.220.11.4.4.1
		dpPresetGroup	OBJECT-GROUP
			OBJECTS	{ presetActive }
			STATUS	current
			DESCRIPTION 
				"A collection of all preset information."
			::= { dpGroups 1 }

		-- 1.3.6.1.4.1.12612.220.11.4.4.2
		dpS2InputGroup	OBJECT-GROUP
			OBJECTS	{ s2InputSelected, s2InputFileSelected }
			STATUS	current
			DESCRIPTION 
				"A collection of all Series2 input information."
			::= { dpGroups 2 }
            
		-- 1.3.6.1.4.1.12612.220.11.4.4.3
		dpDiagnosisGroup	OBJECT-GROUP
			OBJECTS	{ temperature, temperatureMin, temperatureMax, temperatureMinWarning, temperatureMaxWarning, temperatureDiagnosis, temperatureName,
			          voltage, voltageMin, voltageMax, voltageMinWarning, voltageMaxWarning, voltageDiagnosis, voltageName,
			          fanSpeed, fanSpeedMin, fanSpeedMax, fanSpeedMinWarning, fanSpeedMaxWarning, fanSpeedDiagnosis, fanSpeedName
                    }
			STATUS	current
			DESCRIPTION
				"A collection of all DP diagnosis properties"
			::= { dpGroups 3 }

		-- 1.3.6.1.4.1.12612.220.11.4.4.4
		dpNotificationGroup	NOTIFICATION-GROUP
			NOTIFICATIONS	{ temperatureFail, voltageFail, fanSpeedFail,
			                  temperatureWarning, voltageWarning, fanSpeedWarning }
			STATUS	current
			DESCRIPTION
				"The collection of all DPS1S2 notifications."
			::= { dpGroups 4 }

		-- 1.3.6.1.4.1.12612.220.11.4.4.5
		dpTrapGroup	NOTIFICATION-GROUP
			NOTIFICATIONS	{ trapTemperatureFail, trapVoltageFail, trapFanSpeedFail,
			          trapTemperatureWarning, trapVoltageWarning, trapFanSpeedWarning }
			STATUS	current
			DESCRIPTION
				"The collection of all DPS1S2 traps."
			::= { dpGroups 5 }
			
-- END OF BARCO-ME-DC-DPS1S2-MON-MIB mib

		-- 1.3.6.1.4.1.12612.220.11.5.1
		bmedcMediaServerMonModule	OBJECT-IDENTITY
		    STATUS	current
            DESCRIPTION 
				"This is the former module identifiaction item which is now in the common declaration."
			::= { rootBmeDcMediaServerMonMIB 1 }
		
	
-- Properties to monitor
   
		-- 1.3.6.1.4.1.12612.220.11.5.2
		icmpProp2Monitor	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the general oid for the properties to monitor."
			::= { rootBmeDcMediaServerMonMIB 2 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.1
		icmpHostName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the name of the media server."
			::= { icmpProp2Monitor 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.2
		icmpSerialNumber	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the serial number of the media server."
			::= { icmpProp2Monitor 2 }
                                                
		-- 1.3.6.1.4.1.12612.220.11.5.2.3
		icmpState	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current state of the media server.
				Possible values: 
				 - 'Starting'
				 - 'Running'
				 - 'Update in progress'
				 - 'Shutting down'"
			::= { icmpProp2Monitor 3 }
                                           
		-- 1.3.6.1.4.1.12612.220.11.5.2.4
		icmpMediaBlockCertifID	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the certificate ID of the mediablock."
			::= { icmpProp2Monitor 4 }
                                           
		-- 1.3.6.1.4.1.12612.220.11.5.2.5
		icmpSoftwareVersion	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the installed software version of the media server."
			::= { icmpProp2Monitor 5 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.6
		icmpLicenseTable	OBJECT-TYPE
			SYNTAX SEQUENCE OF IcmpLicenseEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A table with all ICMP licenses."
			::= { icmpProp2Monitor 6 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.6.1
		icmpLicenseEntry	OBJECT-TYPE
			SYNTAX	IcmpLicenseEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"An entry with version info for a specific software or firmware component."
			INDEX	{ icmpLicenseIndex }
			::= { icmpLicenseTable 1 }

		IcmpLicenseEntry ::=
			SEQUENCE {
				icmpLicenseIndex            Unsigned32,
				icmpLicenseName             DisplayString,
				icmpLicenseNotValidBefore   DateAndTime,
				icmpLicenseNotValidAfter    DateAndTime 
			}

		-- 1.3.6.1.4.1.12612.220.11.5.2.6.1.1
		icmpLicenseIndex	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..10)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"ICMP license index"
			::= { icmpLicenseEntry 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.6.1.2
		icmpLicenseName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"Name of the retrieved license."
			::= { icmpLicenseEntry 2 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.6.1.3
		icmpLicenseNotValidBefore	OBJECT-TYPE
			SYNTAX	DateAndTime
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"Specifies the date before which the license is not valid."
			::= { icmpLicenseEntry 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.6.1.4
		icmpLicenseNotValidAfter	OBJECT-TYPE
			SYNTAX	DateAndTime
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"Specifies the date after which the license is not valid."
			::= { icmpLicenseEntry 4 }


		-- 1.3.6.1.4.1.12612.220.11.5.2.7
		icmpSensorTables	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the sensor tables."
			::= { icmpProp2Monitor 7 }
                                               
		-- 1.3.6.1.4.1.12612.220.11.5.2.7.1
		icmpTemperatureTable	OBJECT-TYPE
			SYNTAX SEQUENCE OF	IcmpTemperatureEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A table with temperature entries from the ICMP."
			::= { icmpSensorTables 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.1.1
		icmpTemperatureEntry	OBJECT-TYPE
			SYNTAX	IcmpTemperatureEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A temperature diagnosis entry"
			INDEX	{ icmpTemperatureIndex }
			::= { icmpTemperatureTable 1 }

		IcmpTemperatureEntry ::=
		    SEQUENCE {
				icmpTemperatureIndex       Unsigned32,
				icmpTemperatureName        DisplayString,
				icmpTemperature            TemperatureValue,
				icmpTemperatureDiagnosis	Diagnosis
			}

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.1.1.1
		icmpTemperatureIndex	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"Indentifies the temperature diagnosis entry."	
			::= { icmpTemperatureEntry 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.1.1.2
		icmpTemperatureName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current measured temperature name."
			::= { icmpTemperatureEntry 2 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.1.1.3
		icmpTemperature	OBJECT-TYPE
			SYNTAX	TemperatureValue
			UNITS	"Degrees Celcius"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current temperature."
			::= { icmpTemperatureEntry 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.1.1.4
		icmpTemperatureDiagnosis	OBJECT-TYPE
			SYNTAX	Diagnosis
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"Diagnosis current Temperature against its limits."
			::= { icmpTemperatureEntry 4 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.2
		icmpVoltageTable	OBJECT-TYPE
			SYNTAX SEQUENCE OF	IcmpVoltageEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A table with voltage entries from the media server."
			::= { icmpSensorTables 2 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.2.1
		icmpVoltageEntry	OBJECT-TYPE
			SYNTAX	IcmpVoltageEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A voltage diagnosis entry"
			INDEX	{ icmpVoltageIndex }
			::= { icmpVoltageTable 1 }

		IcmpVoltageEntry ::=
		    SEQUENCE {
				icmpVoltageIndex		Unsigned32,
				icmpVoltageName			DisplayString,
				icmpVoltage				VoltageValue,
				icmpVoltageDiagnosis	Diagnosis
			}

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.2.1.1
		icmpVoltageIndex	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"Indentifies the voltage diagnosis entry."	
			::= { icmpVoltageEntry 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.2.1.2
		icmpVoltageName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current measured voltage name."
			::= { icmpVoltageEntry 2 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.2.1.3
		icmpVoltage	OBJECT-TYPE
			SYNTAX	VoltageValue
			UNITS	"mV"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current voltage."
			::= { icmpVoltageEntry 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.2.1.4
		icmpVoltageDiagnosis	OBJECT-TYPE
			SYNTAX	Diagnosis
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"Diagnosis current voltage against its limits."
			::= { icmpVoltageEntry 4 }


		-- 1.3.6.1.4.1.12612.220.11.5.2.7.3
		icmpFanSpeedTable	OBJECT-TYPE
			SYNTAX SEQUENCE OF	IcmpFanSpeedEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A table with fan speed entries from the media server."
			::= { icmpSensorTables 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.3.1
		icmpFanSpeedEntry	OBJECT-TYPE
			SYNTAX	IcmpFanSpeedEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A fan speed diagnosis entry :
				[1] CPU Fan
				[2] System Fan 
				"
			INDEX	{ icmpFanSpeedIndex }
			::= { icmpFanSpeedTable 1 }

		IcmpFanSpeedEntry ::=
		    SEQUENCE {
				icmpFanSpeedIndex		Unsigned32,
				icmpFanSpeedName		DisplayString,
				icmpFanSpeed			FanSpeedValue,
				icmpFanSpeedDiagnosis	Diagnosis
			}

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.3.1.1
		icmpFanSpeedIndex	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"Indentifies the fan speed diagnosis entry."	
			::= { icmpFanSpeedEntry 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.3.1.2
		icmpFanSpeedName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current measured fan speed name."
			::= { icmpFanSpeedEntry 2 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.3.1.3
		icmpFanSpeed	OBJECT-TYPE
			SYNTAX	FanSpeedValue
			UNITS	"RPM (rounds per minute)"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current fan speed."
			::= { icmpFanSpeedEntry 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.7.3.1.4
		icmpFanSpeedDiagnosis	OBJECT-TYPE
			SYNTAX	Diagnosis
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"Diagnosis current fanspeed against its limits."
			::= { icmpFanSpeedEntry 4 }



		-- 1.3.6.1.4.1.12612.220.11.5.2.8
		icmpInternalRaid	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the general oid for the server's raid array."
			::= { icmpProp2Monitor 8 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.8.1
		icmpInternalRaidModel	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the model name of the media server's raid array."
			::= { icmpInternalRaid 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.8.2
		icmpInternalRaidSerialNumber	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the serial number of the media server's raid array."
			::= { icmpInternalRaid 2 }
                                    
		-- 1.3.6.1.4.1.12612.220.11.5.2.8.3
		icmpInternalRaidStatus	OBJECT-TYPE
			SYNTAX INTEGER
				{
				raidOptimal(0),
				degraded(1),
				rebuild(2),
				raidMissing(3),
				unknown(4)
				}
			UNITS	"status enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"The status of of the media server's system hard disk:           
				
				raidOptimal: The raid array usage is optimal
				degraded:    The raid array is degraded
				rebuild:     The raid array is rebuilding
				raidMissing: The raid array is missing
                unknown:     The status of the raid array is unknown
				"
			::= { icmpInternalRaid 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.8.4
		icmpInternalRaidRebuildPercentage	OBJECT-TYPE
			SYNTAX	Unsigned32
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the rebuild percentage of the ICMP raid array."
			::= { icmpInternalRaid 4 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.8.5
		icmpInternalRaidHDDTable	OBJECT-TYPE
			SYNTAX SEQUENCE OF	RaidDiskEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A table with raid disk entries."
			::= { icmpInternalRaid 5 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1
		raidDiskEntry	OBJECT-TYPE
			SYNTAX	RaidDiskEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A raid disk entry."
			INDEX	{ raidDiskIndex }
			::= { icmpInternalRaidHDDTable 1 }

		RaidDiskEntry ::=
		    SEQUENCE {
				raidDiskIndex	    	Unsigned32,        
				raidDiskSerialNumber    DisplayString,   
				raidDiskSize            Unsigned32,
				raidDiskStatus			INTEGER,
				raidDiskCurrentTemperature TemperatureValue,
				raidDiskHighestTemperature TemperatureValue,
				raidDiskLowestTemperature  TemperatureValue
		    }

		--- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1.1
	    raidDiskIndex	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"Indentifies the raid array disk list entry."
			::= { raidDiskEntry 1 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1.2
		raidDiskSerialNumber	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the raid disk serial number."
			::= { raidDiskEntry 2 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1.3
		raidDiskSize	OBJECT-TYPE
			SYNTAX	Unsigned32
			UNITS	"megabytes"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the raid disk total size."
			::= { raidDiskEntry 3 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1.4
		raidDiskStatus	OBJECT-TYPE
			SYNTAX INTEGER
				{
				unknown(0),
				optimal(1),
				failed(2)
				}
			UNITS	"status enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the raid disk status:  
				                                         
                unknown:   The status of the raid disk cannot be determined
				optimal:   The raid disk usage is optimal
				failed:    The raid disk shows a failure
				"
			::= { raidDiskEntry 4 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1.5
		raidDiskCurrentTemperature OBJECT-TYPE
			SYNTAX	TemperatureValue
			UNITS	"Degrees Celcius"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current temperature of the hard drive."
			::= { raidDiskEntry 5 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1.6
		raidDiskHighestTemperature OBJECT-TYPE
			SYNTAX	TemperatureValue
			UNITS	"Degrees Celcius"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the highest recorded temperature of the hard drive."
			::= { raidDiskEntry 6 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.8.5.1.7
		raidDiskLowestTemperature OBJECT-TYPE
			SYNTAX	TemperatureValue
			UNITS	"Degrees Celcius"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the lowest recorded temperature of the hard drive."
			::= { raidDiskEntry 7 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.8.6
		icmpInternalRaidTotalSize OBJECT-TYPE
			SYNTAX	Unsigned32
			UNITS	"megabytes"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the total usable size of the ICMP raid array."
			::= { icmpInternalRaid 6 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.9
		icmpStorageTable	OBJECT-TYPE
			SYNTAX SEQUENCE OF	StorageEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A table with storage entries."
			::= { icmpProp2Monitor 9 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.9.1
		storageEntry	OBJECT-TYPE
			SYNTAX	StorageEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A storage entry."
			INDEX	{ storageIndex }
			::= { icmpStorageTable 1 }

		StorageEntry ::=
		    SEQUENCE {
				storageIndex	    	Unsigned32,        
				storageName             DisplayString,   
			    storageType             DisplayString,     
				storageTotalSize    	Unsigned32,        
				storageFreeSize     	Unsigned32												
		    }

		--- 1.3.6.1.4.1.12612.220.11.5.2.9.1.1
	    storageIndex	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"Indentifies the storage list entry."
			::= { storageEntry 1 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.9.1.2
		storageName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the storage name."
			::= { storageEntry 2 }           
			
		--- 1.3.6.1.4.1.12612.220.11.5.2.9.1.3
		storageType	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the storage type."
			::= { storageEntry 3 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.9.1.4
	    storageTotalSize	OBJECT-TYPE
			SYNTAX	Unsigned32
			UNITS	"megabytes"
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"This is the storage total size."
			::= { storageEntry 4 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.9.1.5
	    storageFreeSize	OBJECT-TYPE
			SYNTAX	Unsigned32
			UNITS	"megabytes"
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"This is the storage available free size."
			::= { storageEntry 5 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.10
		icmpContent	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about content on the ICMP."
			::= { icmpProp2Monitor 10 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.10.1
		icmpIngestCurrentJobStatus	OBJECT-TYPE
			SYNTAX INTEGER
				{
				unknown(0),
				ingestRunning(1),
				ingestIdle(2)
				}
			UNITS	"ingest status enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the ingest job status:  
				                                         
                unknown:        The status of the ingest cannot be determined
				ingestRunning:  The ingest job is currently running
				ingestIdle:     The ingest is in idle state.
				"
			::= { icmpContent 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.10.2
		icmpIngestJobsPending	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"This is the number of ingest jobs pending (in the queue)."	
			::= { icmpContent 2 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.10.3
		icmpIngestSource	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about the current ingest source."
			::= { icmpContent 3 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.10.3.1
		icmpIngestSourceType	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current ingest source type."
			::= { icmpIngestSource 1 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.10.3.2
		icmpIngestSourceName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current ingest source name."
			::= { icmpIngestSource 2 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.10.3.3
		icmpIngestSourceConnectionStatus	OBJECT-TYPE
			SYNTAX INTEGER
				{
				notConnected(0),
				connected(1)
				}
			UNITS	"ingest source connection enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the raid disk status:  
				                                         
                notConnected:  The ingest source is not connected
				connected:     The ingest source is connected
				"
			::= { icmpIngestSource 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.10.3.4
		icmpIngestProgression	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about the ingest job progression."
			::= { icmpContent 4 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.10.3.4.1
		icmpIngestStartTime	OBJECT-TYPE
			SYNTAX	DateAndTime
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the current ingest start time."
			::= { icmpIngestProgression 1 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.10.3.4.2
		icmpIngestPercentageCompleted	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"This is the completion percentage of the current ingest job."	
			::= { icmpIngestProgression 2 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.10.3.4.3
		icmpIngestElapsedTime	OBJECT-TYPE
			SYNTAX	Unsigned32
			UNITS "seconds"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is elapsed time of the current ingest job."
			::= { icmpIngestProgression 3 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.11
		icmpPlayer	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about the ICMP Player."
			::= { icmpProp2Monitor 11 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.11.1
		icmpPlayMode	OBJECT-TYPE
			SYNTAX INTEGER
				{
				manual(0),
				scheduled(1)
				}
			UNITS	"ICMP play mode enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the ICMP play mode:  
				                                         
                manual:        The player is in manual mode (the scheduler is turned off).
				scheduled:     The player is using the scheduler.
				"
			::= { icmpPlayer 1 }

        --- 1.3.6.1.4.1.12612.220.11.5.2.11.2
		icmpPlayState	OBJECT-TYPE
			SYNTAX INTEGER
				{
				playing(0),
				paused(1),
				stopped(2)
				}
			UNITS	"ICMP play state enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the ICMP play state:  
				                                         
                playing:        The player is playing content.
				paused:         The player is paused.
                stopped:        The player has been stopped.
				"
			::= { icmpPlayer 2 }

   		-- 1.3.6.1.4.1.12612.220.11.5.2.11.3
		icmpPlaySelection	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about the current play selection."
			::= { icmpPlayer 3 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.3.1
		icmpPlaySelectContentTitle	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the title of the currently selected show."
			::= { icmpPlaySelection 1 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.3.2
		icmpPlaySelectContentDuration	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			UNITS "seconds"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the duration of the selected play content (in seconds)."
			::= { icmpPlaySelection 2 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.3.3
		icmpPlaySelectStartTime	OBJECT-TYPE
			SYNTAX	DateAndTime
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the scheduled start time of the selected play content."
			::= { icmpPlaySelection 3 }

   		-- 1.3.6.1.4.1.12612.220.11.5.2.11.3.4
		icmpPlayProgression	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about the progression of the current play selection."
			::= { icmpPlayer 4 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.4.1
		icmpPlayCurrentContentTitle	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the title of the currently playing clip."
			::= { icmpPlayProgression 1 }
                                                    
   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.4.2
		icmpPlayStartTime	OBJECT-TYPE
			SYNTAX	DateAndTime
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the start time of the play content currently playing."
			::= { icmpPlayProgression 2 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.4.3
		icmpPlayPosition	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			UNITS "seconds"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the play position of the content (in seconds) currently being played."
			::= { icmpPlayProgression 3 }

        --- 1.3.6.1.4.1.12612.220.11.5.2.11.4.4
		icmpPlayFromAlternativeSource	OBJECT-TYPE
			SYNTAX INTEGER
				{
				false(0),
				true(1)
				}
			UNITS	"ICMP alternative source selection enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the ICMP alternative source selection:  
				                                         
                false:        The content is not played from alternative content sources.
				true:         The content is not played from alternative content sources.
				"
			::= { icmpPlayProgression 4 }

   		-- 1.3.6.1.4.1.12612.220.11.5.2.11.3.5
		icmpPlayerNextSchedule	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about the next scheduled content."
			::= { icmpPlayer 5 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.3.5.1
		icmpPlayNextScheduledContentTitle	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the title of the content scheduled next."
			::= { icmpPlayerNextSchedule 1 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.3.5.2
		icmpPlayNextScheduledContentDuration	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			UNITS "seconds"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the duration of the next scheduled content (in seconds)."
			::= { icmpPlayerNextSchedule 2 }

   		--- 1.3.6.1.4.1.12612.220.11.5.2.11.3.5.3
		icmpPlayNextScheduledStartTime	OBJECT-TYPE
			SYNTAX	DateAndTime
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the start time of the next scheduled content."
			::= { icmpPlayerNextSchedule 3 }

        --- 1.3.6.1.4.1.12612.220.11.5.2.11.3.5.4
		icmpPlayNextScheduledValidity	OBJECT-TYPE
			SYNTAX INTEGER
				{
				invalid(0),
				valid(1)
				}
			UNITS	"ICMP next scheduled content validity enumeration"
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the validity status of the content that is scheduled next:  
				                                         
                invalid:      The show that is scheduled next is not not valid.
				valid:        The show that is scheduled next is not not valid.
				"
			::= { icmpPlayerNextSchedule 4 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.12
		icmpScheduler	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the node that gathers the information about the ICMP Player."
			::= { icmpProp2Monitor 12 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.12.1
		icmpUnplayableScheduledContentTable	OBJECT-TYPE
			SYNTAX SEQUENCE OF	UnplayableContentEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"A table with unplayable scheduled content entries."
			::= { icmpScheduler 1 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.12.1.1
		icmpUnplayableContentEntry	OBJECT-TYPE
			SYNTAX	UnplayableContentEntry
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"An unplayable scheduled content entry."
			INDEX	{ unplayableContentIndex }
			::= { icmpUnplayableScheduledContentTable 1 }

		UnplayableContentEntry ::=
		    SEQUENCE {
				unplayableContentIndex         Unsigned32,           
				unplayableContentShow          DisplayString,   
				unplayableContentShowTitle     DisplayString,   
			    unplayableContentTime          DateAndTime,     
			    unplayableContentReason        DisplayString
		    }

		--- 1.3.6.1.4.1.12612.220.11.5.2.12.1.1.1
	    unplayableContentIndex	OBJECT-TYPE
			SYNTAX	Unsigned32 (0..65535)
			MAX-ACCESS	not-accessible
			STATUS	current
			DESCRIPTION
				"Indentifies the unplayable scheduled content list entry."
			::= { icmpUnplayableContentEntry 1 }

        --- 1.3.6.1.4.1.12612.220.11.5.2.12.1.1.2
        unplayableContentShow OBJECT-TYPE
        	SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the list name of the scheduled show that has unplayable content."
			::= { icmpUnplayableContentEntry 2 }           
        
		--- 1.3.6.1.4.1.12612.220.11.5.2.12.1.1.3
		unplayableContentShowTitle	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the title of the scheduled show that has unplayable content."
			::= { icmpUnplayableContentEntry 3 }           
			
		--- 1.3.6.1.4.1.12612.220.11.5.2.12.1.1.5
		unplayableContentTime	OBJECT-TYPE
			SYNTAX	DateAndTime
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the time of the scheduled show that has unplayable content."
			::= { icmpUnplayableContentEntry 5 }

		--- 1.3.6.1.4.1.12612.220.11.5.2.12.1.1.6
		unplayableContentReason	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
				"This is the reason for the scheduled content not to be playable."
			::= { icmpUnplayableContentEntry 6 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.13
				icmpMode2D3D	OBJECT-TYPE
					SYNTAX	DisplayString
					MAX-ACCESS	read-only
					STATUS	current
					DESCRIPTION
						"This indicates if the media server is currently in 2D or 3D mode.
						Possible values: 
						 - '2D'
						 - '3D'"
			::= { icmpProp2Monitor 13 }

		-- 1.3.6.1.4.1.12612.220.11.5.2.14
				icmpBackplaneTest	OBJECT-TYPE
					SYNTAX	DisplayString
					MAX-ACCESS	read-only
					STATUS	current
					DESCRIPTION
						"This indicates the result of the test on the backplane.
			::= { icmpProp2Monitor 14 }
                                           

                                                   
-- Notifications

		-- 1.3.6.1.4.1.12612.220.11.5.5
		barcoMeDcMediaServerNotifications	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the general oid for Barco Media Server notifications."
			::= { rootBmeDcMediaServerMonMIB 5 }


		-- 1.3.6.1.4.1.12612.220.11.5.5.0
		icmpNotificationPrefix	OBJECT-IDENTITY
			STATUS	current
			DESCRIPTION
				"This is the prefix used to have easy event mapping
				between notification oid values (SNMPv2 and SNMPv3) and
				specific trap numbers (SNMPv1)."
			::= { barcoMeDcMediaServerNotifications 0 }


		-- 1.3.6.1.4.1.12612.220.11.5.5.0.1
		icmpTemperatureFail	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a critical severity and is sent the moment of
				exceeding one of the temperature boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { icmpNotificationPrefix 1 }


		-- 1.3.6.1.4.1.12612.220.11.5.5.0.2
		icmpVoltageFail	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This has a critical severity and is sent the moment of
				exceeding one of the voltage boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { icmpNotificationPrefix 2 }


		-- 1.3.6.1.4.1.12612.220.11.5.5.0.3
		icmpFanSpeedFail	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a major severity and is sent the moment of
				exceeding one of the fan speed boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { icmpNotificationPrefix 3 }


		-- 1.3.6.1.4.1.12612.220.11.5.5.0.4
		icmpTemperatureWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the temperature boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { icmpNotificationPrefix 4 }


		--- 1.3.6.1.4.1.12612.220.11.5.5.0.5
		icmpVoltageWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the voltage boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { icmpNotificationPrefix 5 }


		-- 1.3.6.1.4.1.12612.220.11.5.5.0.6
		icmpFanSpeedWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment of
				exceeding one of the fanspeed boundaries.
				Details could be found by getting the eventDetail object.
				The trap will be resent every time the projector is switched on."
			::= { icmpNotificationPrefix 6 }

		-- 1.3.6.1.4.1.12612.220.11.5.5.0.7
		icmpRaidError	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment the raid array
				of the server is not running in optimal conditions (error).
				Details could be found by getting the eventDetail object.
				The trap will be resent at a regular period if the problem remains."
			::= { icmpNotificationPrefix 7 }

		-- 1.3.6.1.4.1.12612.220.11.5.5.0.8
		icmpRaidWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment the raid array
				of the server is not running in optimal conditions (warning).
				Details could be found by getting the eventDetail object.
				The trap will be resent at a regular period if the problem remains."
			::= { icmpNotificationPrefix 8 }

		-- 1.3.6.1.4.1.12612.220.11.5.5.0.9
		icmpRaidDiskError	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment the system disk
				of the server is not running in optimal conditions (error).
				Details could be found by getting the eventDetail object.
				The trap will be resent at a regular period if the problem remains."
			::= { icmpNotificationPrefix 9 }

		-- 1.3.6.1.4.1.12612.220.11.5.5.0.10
		icmpRaidDiskWarning	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
			DESCRIPTION
				"This trap has a warning severity and is sent the moment the system disk
				of the server is not running in optimal conditions (warning).
				Details could be found by getting the eventDetail object.
				The trap will be resent at a regular period if the problem remains."
			::= { icmpNotificationPrefix 10 }

		-- 1.3.6.1.4.1.12612.220.11.5.5.0.11
		icmpStorageError	NOTIFICATION-TYPE
			OBJECTS	{ eventSeverity, eventDescription, eventDetail }
			STATUS	current
