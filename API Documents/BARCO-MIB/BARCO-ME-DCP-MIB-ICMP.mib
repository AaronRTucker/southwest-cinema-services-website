		-- 1.3.6.1.4.1.12612.220.11.4.2.1.3.1.8
		fanSpeedName	OBJECT-TYPE
			SYNTAX	DisplayString
			MAX-ACCESS	read-only
			STATUS	current
			DESCRIPTION
