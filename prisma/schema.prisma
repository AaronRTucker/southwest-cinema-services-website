generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String?
  role      Role       @default(CUSTOMER)
  locations Location[] @relation("UserLocations")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

enum Role {
  ADMIN
  CUSTOMER
}

model Location {
  id             String           @id @default(cuid())
  name           String
  address        String?
  city           String?
  state          String?
  zip            String?
  customer       String?
  siteId         String?          @unique
  users          User[]           @relation("UserLocations")
  auditoriums    Auditorium[]
  equipment      Equipment[]
  pmReports      PMReport[]
  serviceRecords ServiceRecord[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Auditorium {
  id              String               @id @default(cuid())
  number          Int
  name            String?
  locationId      String
  location        Location             @relation(fields: [locationId], references: [id])
  equipment       Equipment[]
  screenWidth     Float?
  screenHeight    Float?
  screenAspect    String?
  seatingCapacity Int?
  hasAtmos        Boolean              @default(false)
  hasDtsx         Boolean              @default(false)
  is4K            Boolean              @default(true)
  isLaser         Boolean              @default(false)
  attributes      AuditoriumAttribute[]
  pmReports       PMReport[]
  serviceRecords  ServiceRecord[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model AuditoriumAttribute {
  id           String     @id @default(cuid())
  auditoriumId String
  auditorium   Auditorium @relation(fields: [auditoriumId], references: [id])
  key          String
  value        String
  createdAt    DateTime   @default(now())
}

model Equipment {
  id              String               @id @default(cuid())
  name            String
  type            EquipmentType
  manufacturer    String?
  model           String?
  serialNumber    String?
  firmwareVersion String?
  installDate     DateTime?
  warrantyExpiry  DateTime?
  relayId         String?
  locationId      String
  location        Location             @relation(fields: [locationId], references: [id])
  auditoriumId    String?
  auditorium      Auditorium?          @relation(fields: [auditoriumId], references: [id])
  serviceRecords  ServiceRecord[]
  attributes      EquipmentAttribute[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
}

model EquipmentAttribute {
  id          String    @id @default(cuid())
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  key         String
  value       String
  createdAt   DateTime  @default(now())
}

enum EquipmentType {
  PROJECTOR
  SOUND
  SERVER
  NETWORK
  OTHER
}

model ServiceRecord {
  id          String      @id @default(cuid())
  date        DateTime
  type        ServiceType @default(OTHER)
  description String
  technician  String?
  notes       String?
  parts       String?
  equipmentId String?
  equipment   Equipment?  @relation(fields: [equipmentId], references: [id])
  locationId  String?
  location    Location?   @relation(fields: [locationId], references: [id])
  auditoriumId String?
  auditorium  Auditorium? @relation(fields: [auditoriumId], references: [id])
  createdAt   DateTime    @default(now())
}

enum ServiceType {
  PM
  REPAIR
  EMERGENCY
  INSTALL
  INSPECTION
  OTHER
}

model PMReport {
  id           String            @id @default(cuid())
  date         DateTime
  summary      String
  details      String?
  technician   String?
  locationId   String
  location     Location          @relation(fields: [locationId], references: [id])
  auditoriumId String?
  auditorium   Auditorium?       @relation(fields: [auditoriumId], references: [id])
  items        PMChecklistItem[]
  createdAt    DateTime          @default(now())
}

model PMChecklistItem {
  id         String   @id @default(cuid())
  pmReportId String
  pmReport   PMReport @relation(fields: [pmReportId], references: [id])
  category   String
  task       String
  completed  Boolean  @default(false)
  notes      String?
}
